@baseUrl = http://localhost:3000/api/user
@accessToken = PON_AQUI_EL_ACCESS_TOKEN
@refreshToken = PON_AQUI_EL_REFRESH_TOKEN

### 1) Registro de usuario
POST {{baseUrl}}/register
Content-Type: application/json

{
  "email": "ana@example.com",
  "password": "password123"
}

### 2) Validación del email
PUT {{baseUrl}}/validation
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "code": "123456"
}

### 3) Login
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "ana@example.com",
  "password": "password123"
}

### 4a) Onboarding — datos personales
PUT {{baseUrl}}/register
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Ana",
  "lastName": "García Pérez",
  "nif": "12345678Z"
}

### 4b) Onboarding — compañía (empresa normal)
PATCH {{baseUrl}}/company
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "isFreelance": false,
  "name": "Acme Corp",
  "cif": "B12345678",
  "address": {
    "street": "Calle Mayor",
    "number": "1",
    "postal": "28001",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### 4b bis) Onboarding — compañía (autónomo)
PATCH {{baseUrl}}/company
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "isFreelance": true
}

### 5) Logo de la compañía (multipart/form-data)
PATCH {{baseUrl}}/logo
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=BOUNDARY

--BOUNDARY
Content-Disposition: form-data; name="logo"; filename="logo.png"
Content-Type: image/png

< ./logo.png
--BOUNDARY--

### 6) Obtener usuario autenticado
GET {{baseUrl}}
Authorization: Bearer {{accessToken}}

### 7a) Refrescar access token
POST {{baseUrl}}/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### 7b) Logout
POST {{baseUrl}}/logout
Authorization: Bearer {{accessToken}}

### 8) Eliminar usuario (soft delete)
DELETE {{baseUrl}}?soft=true
Authorization: Bearer {{accessToken}}

### 8 bis) Eliminar usuario (hard delete)
DELETE {{baseUrl}}
Authorization: Bearer {{accessToken}}

### 9) Cambiar contraseña
PUT {{baseUrl}}/password
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "currentPassword": "password123",
  "newPassword": "newPassword456"
}

### 10) Invitar compañero
POST {{baseUrl}}/invite
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "email": "invitado@example.com",
  "name": "Luis",
  "lastName": "Martínez"
}
